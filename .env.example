# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Binance API Configuration (Optional - bot will use public API if not provided)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# How to get these credentials:
# 
# 1. TELEGRAM_BOT_TOKEN:
#    - Message @BotFather on Telegram
#    - Create a new bot with /newbot
#    - Copy the token provided
#
# 2. BINANCE_API_KEY & BINANCE_API_SECRET:
#    - Go to https://www.binance.com/en/my/settings/api-management
#    - Create a new API key
#    - Copy both the API Key and Secret Key
#    - Note: These are optional - the bot will work with public API if not provided
