# Database Configuration
DATABASE_URL="file:./prisma/dev.db"          # Development (SQLite)
# DATABASE_URL="postgresql://user:pass@localhost:5432/rabtradebot"  # Production
# PostgreSQL pool tuning (used when DATABASE_URL is PostgreSQL)
# DATABASE_POOL_MAX=10
# DATABASE_POOL_TIMEOUT_SEC=5
# PGBOUNCER_ENABLED=true

# SQLite -> PostgreSQL migration script inputs
# SQLITE_DATABASE_URL="file:./prisma/dev.db"
# POSTGRES_DATABASE_URL="postgresql://user:pass@localhost:5432/rabtradebot"
# MIGRATION_DRY_RUN=true
# MIGRATION_TRUNCATE_TARGET=false
# MIGRATION_BATCH_SIZE=500

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Binance API Configuration (Optional - bot will use public API if not provided)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Enable Binance Spot Testnet (recommended for Fase 1 development)
BINANCE_TESTNET=true
# Optional explicit Testnet URL
BINANCE_TESTNET_URL=https://testnet.binance.vision
# Optional override for region-specific endpoint
# BINANCE_BASE_URL=https://api.binance.com
# Optional order service tuning
# BINANCE_RECV_WINDOW=5000
# BINANCE_ORDER_TIMEOUT_MS=12000
# BINANCE_MAX_WEIGHT_PER_MINUTE=1200
# Optional outbound proxy when server IP is blocked by Binance (format: http://user:pass@host:port)
# BINANCE_PROXY_URL=http://127.0.0.1:8080
# Optional TLS settings for environments with custom CA/proxy inspection
# BINANCE_CA_CERT_PATH=/etc/ssl/certs/ca-certificates.crt
# BINANCE_TLS_INSECURE=false

# Twitter API Configuration (Optional - for social media analysis)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_KEY_SECRET=your_twitter_api_key_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Chutes AI Configuration (NEW! - for advanced news analysis)
CHUTES_API_KEY=your_chutes_api_key_here

# How to get these credentials:
#
# 1. TELEGRAM_BOT_TOKEN:
#    - Message @BotFather on Telegram
#    - Create a new bot with /newbot
#    - Copy the token provided
#
# 2. BINANCE_API_KEY & BINANCE_API_SECRET:
#    - Go to https://www.binance.com/en/my/settings/api-management
#    - Create a new API key
#    - Copy both the API Key and Secret Key
#    - Note: These are optional - the bot will work with public API if not provided
#
# 3. TWITTER API CREDENTIALS:
#    - Go to https://developer.twitter.com/
#    - Create a developer account and new project
#    - Generate API keys and access tokens
#    - See TWITTER_SETUP.md for detailed instructions
#    - Note: These are optional - news analysis will work without Twitter integration
#
# 4. CHUTES_API_KEY:
#    - Go to https://chutes.ai/
#    - Sign up for an account
#    - Go to Settings > API
#    - Generate an API key
#    - Copy the API key
#    - Note: This enables advanced AI-powered news analysis and price impact predictions
#    - Uses GPT-4o-mini for optimal crypto market predictions
