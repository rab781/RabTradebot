# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Binance API Configuration (Optional - bot will use public API if not provided)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Twitter API Configuration (Optional - for social media analysis)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_KEY_SECRET=your_twitter_api_key_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Perplexity AI Configuration (NEW! - for advanced news analysis)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# How to get these credentials:
#
# 1. TELEGRAM_BOT_TOKEN:
#    - Message @BotFather on Telegram
#    - Create a new bot with /newbot
#    - Copy the token provided
#
# 2. BINANCE_API_KEY & BINANCE_API_SECRET:
#    - Go to https://www.binance.com/en/my/settings/api-management
#    - Create a new API key
#    - Copy both the API Key and Secret Key
#    - Note: These are optional - the bot will work with public API if not provided
#
# 3. TWITTER API CREDENTIALS:
#    - Go to https://developer.twitter.com/
#    - Create a developer account and new project
#    - Generate API keys and access tokens
#    - See TWITTER_SETUP.md for detailed instructions
#    - Note: These are optional - news analysis will work without Twitter integration
#
# 4. PERPLEXITY_API_KEY:
#    - Go to https://www.perplexity.ai/
#    - Sign up for an account
#    - Go to Settings > API
#    - Generate an API key
#    - Copy the API key
#    - Note: This enables advanced AI-powered news analysis and price impact predictions
