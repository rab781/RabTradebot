# Production Environment (Mainnet + PostgreSQL + Info Logs)
NODE_ENV=production
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/rabtradebot?schema=public"

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here

# Binance (Mainnet)
BINANCE_TESTNET=false
BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_KEY=your_binance_mainnet_api_key_here
BINANCE_API_SECRET=your_binance_mainnet_api_secret_here

# AI
CHUTES_API_KEY=your_chutes_api_key_here

# Health monitor
HEALTH_MONITOR_INTERVAL_MS=300000
