{
  "name": "advanced-crypto-trading-bot",
  "version": "1.0.0",
  "description": "A comprehensive Telegram bot for cryptocurrency trading, analysis, backtesting, and paper trading",
  "main": "dist/enhancedBot.js",
  "scripts": {
    "start": "node dist/enhancedBot.js",
    "dev": "nodemon --exec ts-node src/enhancedBot.ts",
    "build": "tsc",
    "deploy": "git pull && npm run build && pm2 restart rabtradebot",
    "clean": "rimraf dist",
    "clean:js": "node scripts/cleanup-js.js",
    "rebuild": "npm run clean && npm run build",
    "test-chutes": "ts-node scripts/test-chutes.ts",
    "test-chutes-api": "ts-node scripts/test-chutes-api.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest"
  },
  "keywords": [
    "telegram",
    "bot",
    "cryptocurrency",
    "trading",
    "signals",
    "technical-analysis",
    "binance",
    "bitcoin",
    "crypto"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/crypto-signal-bot.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/crypto-signal-bot/issues"
  },
  "homepage": "https://github.com/yourusername/crypto-signal-bot#readme",
  "type": "commonjs",
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.3.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "axios": "^1.10.0",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "cryptocompare": "^1.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "mathjs": "^15.1.0",
    "node-binance-api": "^1.0.9",
    "socket.io": "^4.8.3",
    "technicalindicators": "^3.1.0",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "prisma": "^7.3.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
