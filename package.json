{
  "name": "advanced-crypto-trading-bot",
  "version": "1.0.0",
  "description": "A comprehensive Telegram bot for cryptocurrency trading, analysis, backtesting, and paper trading",
  "main": "dist/finalBot.js",
  "scripts": {
    "start": "node dist/finalBot.js",
    "dev": "nodemon --exec ts-node src/finalBot.ts",
    "enhanced": "node dist/enhancedBot.js",
    "dev:enhanced": "nodemon --exec ts-node src/enhancedBot.ts",
    "phase2": "node dist/phase2EnhancedBot.js",
    "dev:phase2": "nodemon --exec ts-node src/phase2EnhancedBot.ts",
    "build": "tsc",
    "build:phase2": "tsc src/phase2EnhancedBot.ts --outDir dist --module commonjs --target es2020 --esModuleInterop --resolveJsonModule --skipLibCheck",
    "quick:phase2": "npm run build:phase2 && npm run phase2",
    "test:ml": "ts-node -e \"console.log('🧠 Testing ML Services...'); import('./src/phase2EnhancedBot').then(m => console.log('✅ All ML imports successful!'))\"",
    "clean": "rimraf dist",
    "clean:js": "node scripts/cleanup-js.js",
    "rebuild": "npm run clean && npm run build",
    "test-twitter": "ts-node scripts/test-twitter.ts",
    "test-twitter-improved": "ts-node scripts/test-twitter-improved.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "diagnose-twitter": "ts-node scripts/diagnose-twitter.ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "cryptocurrency",
    "trading",
    "signals",
    "technical-analysis",
    "binance",
    "bitcoin",
    "crypto"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/crypto-signal-bot.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/crypto-signal-bot/issues"
  },
  "homepage": "https://github.com/yourusername/crypto-signal-bot#readme",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@types/cheerio": "^0.22.35",
    "@types/node-telegram-bot-api": "^0.64.9",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.10.0",
    "cheerio": "^1.0.0",
    "compromise": "^14.14.4",
    "cryptocompare": "^1.0.0",
    "dotenv": "^16.5.0",
    "ml-matrix": "^6.12.1",
    "ml-random-forest": "^2.1.0",
    "natural": "^6.12.0",
    "node-binance-api": "^1.0.9",
    "node-telegram-bot-api": "^0.66.0",
    "plotly.js-dist": "^3.0.1",
    "prisma": "^6.15.0",
    "sentiment": "^5.0.2",
    "sqlite3": "^5.1.7",
    "technicalindicators": "^3.1.0",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "twitter-api-v2": "^1.24.0",
    "typescript": "^5.8.3",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.4.0"
  }
}
