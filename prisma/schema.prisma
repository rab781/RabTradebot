// Prisma schema for RabTradebot
// Trading bot with ML predictions, backtesting, and risk management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// User model - Telegram users
model User {
  id                Int       @id @default(autoincrement())
  telegramId        BigInt    @unique
  username          String?
  firstName         String?
  lastName          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Preferences
  defaultSymbol     String    @default("BTCUSDT")
  riskTolerance     Float     @default(0.02) // 2% default
  notificationsEnabled Boolean @default(true)
  
  // Relations
  trades            Trade[]
  alerts            Alert[]
  preferences       UserPreference[]
  
  @@index([telegramId])
}

// User preferences
model UserPreference {
  id        Int      @id @default(autoincrement())
  userId    Int
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, key])
  @@index([userId])
}

// Trade model - All executed trades
model Trade {
  id                String   @id @default(uuid())
  userId            Int
  symbol            String
  side              String   // LONG, SHORT
  entryPrice        Float
  exitPrice         Float?
  quantity          Float
  leverage          Float    @default(1)
  
  // Strategy info
  strategyName      String
  strategyVersion   String?
  signalStrength    Float?
  mlConfidence      Float?   // ML model confidence if used
  
  // Trade lifecycle
  entryTime         DateTime
  exitTime          DateTime?
  status            String   // OPEN, CLOSED, CANCELLED
  
  // Performance
  profit            Float?
  profitPct         Float?
  fees              Float    @default(0)
  
  // Risk metrics
  stopLoss          Float?
  takeProfit        Float?
  maxDrawdown       Float?
  
  // Metadata
  notes             String?
  tags              String?  // JSON array
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([symbol])
  @@index([status])
  @@index([entryTime])
}

// Strategy performance metrics
model StrategyMetric {
  id                String   @id @default(uuid())
  strategyName      String
  symbol            String
  timeframe         String
  
  // Performance
  totalTrades       Int
  winningTrades     Int
  losingTrades      Int
  winRate           Float
  avgProfit         Float
  avgLoss           Float
  profitFactor      Float
  sharpeRatio       Float
  
  // Risk metrics
  maxDrawdown       Float
  maxDrawdownPct    Float
  calmarRatio       Float
  sortinoRatio      Float
  
  // Trade stats
  avgTradeDuration  Float    // in minutes
  bestTrade         Float
  worstTrade        Float
  
  // Period
  startDate         DateTime
  endDate           DateTime
  
  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([strategyName, symbol, timeframe, startDate])
  @@index([strategyName])
  @@index([symbol])
}

// Historical price data cache
model HistoricalData {
  id        String   @id @default(uuid())
  symbol    String
  timeframe String
  timestamp BigInt   // Unix timestamp
  
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  
  createdAt DateTime @default(now())
  
  @@unique([symbol, timeframe, timestamp])
  @@index([symbol, timeframe])
  @@index([timestamp])
}

// ML Model performance tracking
model MLModelMetric {
  id                String   @id @default(uuid())
  modelName         String
  modelVersion      String
  symbol            String
  
  // Predictions
  totalPredictions  Int
  correctPredictions Int
  accuracy          Float
  
  // Confidence analysis
  avgConfidence     Float
  highConfAccuracy  Float?  // Accuracy when confidence > 0.6
  lowConfAccuracy   Float?  // Accuracy when confidence < 0.3
  
  // Performance by direction
  bullishAccuracy   Float?
  bearishAccuracy   Float?
  
  // Training info
  trainingDate      DateTime?
  trainingSamples   Int?
  trainingEpochs    Int?
  trainingTime      Float?  // seconds
  
  // Period
  startDate         DateTime
  endDate           DateTime
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([modelName, symbol, startDate])
  @@index([modelName])
}

// Price alerts
model Alert {
  id            String   @id @default(uuid())
  userId        Int
  symbol        String
  alertType     String   // PRICE_ABOVE, PRICE_BELOW, VOLUME_SPIKE, ML_SIGNAL
  
  // Alert conditions
  targetPrice   Float?
  condition     String?  // JSON for complex conditions
  
  // Status
  isActive      Boolean  @default(true)
  triggered     Boolean  @default(false)
  triggeredAt   DateTime?
  
  // Metadata
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([symbol])
  @@index([isActive])
}

// Backtest results storage
model BacktestResult {
  id                String   @id @default(uuid())
  strategyName      String
  symbol            String
  timeframe         String
  
  // Configuration
  startDate         DateTime
  endDate           DateTime
  initialBalance    Float
  
  // Results
  finalBalance      Float
  totalProfit       Float
  totalProfitPct    Float
  totalTrades       Int
  winRate           Float
  profitFactor      Float
  sharpeRatio       Float
  maxDrawdown       Float
  maxDrawdownPct    Float
  
  // Trade details (JSON)
  trades            String   // JSON array of trades
  equityCurve       String?  // JSON array of equity points
  
  // Metadata
  parameters        String?  // JSON of strategy parameters
  createdAt         DateTime @default(now())
  
  @@index([strategyName])
  @@index([symbol])
  @@index([startDate])
}

// Error logs for monitoring
model ErrorLog {
  id            String   @id @default(uuid())
  level         String   // ERROR, WARN, INFO
  source        String   // command name, service, etc
  message       String
  stackTrace    String?
  
  // Context
  userId        Int?
  symbol        String?
  metadata      String?  // JSON
  
  createdAt     DateTime @default(now())
  
  @@index([level])
  @@index([source])
  @@index([createdAt])
}
