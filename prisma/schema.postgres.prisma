// Prisma schema for RabTradebot (PostgreSQL variant)
// Use this schema for production deployments with PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  username   String?
  firstName  String?
  lastName   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  defaultSymbol        String  @default("BTCUSDT")
  riskTolerance        Float   @default(0.02)
  notificationsEnabled Boolean @default(true)

  trades      Trade[]
  alerts      Alert[]
  preferences UserPreference[]

  @@index([telegramId])
}

model UserPreference {
  id        Int      @id @default(autoincrement())
  userId    Int
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model Trade {
  id         String @id @default(uuid())
  userId     Int
  symbol     String
  side       String
  entryPrice Float
  exitPrice  Float?
  quantity   Float
  leverage   Float  @default(1)

  strategyName    String
  strategyVersion String?
  signalStrength  Float?
  mlConfidence    Float?

  entryTime DateTime
  exitTime  DateTime?
  status    String

  profit    Float?
  profitPct Float?
  fees      Float  @default(0)

  stopLoss    Float?
  takeProfit  Float?
  maxDrawdown Float?

  notes     String? @db.Text
  tags      String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
  @@index([status])
  @@index([entryTime])
}

model StrategyMetric {
  id           String @id @default(uuid())
  strategyName String
  symbol       String
  timeframe    String

  totalTrades   Int
  winningTrades Int
  losingTrades  Int
  winRate       Float
  avgProfit     Float
  avgLoss       Float
  profitFactor  Float
  sharpeRatio   Float

  maxDrawdown    Float
  maxDrawdownPct Float
  calmarRatio    Float
  sortinoRatio   Float

  avgTradeDuration Float
  bestTrade        Float
  worstTrade       Float

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyName, symbol, timeframe, startDate])
  @@index([strategyName])
  @@index([symbol])
}

model HistoricalData {
  id        String @id @default(uuid())
  symbol    String
  timeframe String
  timestamp BigInt

  open   Float
  high   Float
  low    Float
  close  Float
  volume Float

  createdAt DateTime @default(now())

  @@unique([symbol, timeframe, timestamp])
  @@index([symbol, timeframe])
  @@index([timestamp])
}

model MLModelMetric {
  id           String @id @default(uuid())
  modelName    String
  modelVersion String
  symbol       String

  totalPredictions   Int
  correctPredictions Int
  accuracy           Float

  avgConfidence    Float
  highConfAccuracy Float?
  lowConfAccuracy  Float?

  bullishAccuracy Float?
  bearishAccuracy Float?

  trainingDate    DateTime?
  trainingSamples Int?
  trainingEpochs  Int?
  trainingTime    Float?

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelName, symbol, startDate])
  @@index([modelName])
}

model Prediction {
  id     String @id @default(uuid())
  userId Int
  symbol String

  modelName          String
  modelVersion       String
  predictedDirection String
  confidence         Float
  predictedChange    Float
  currentPrice       Float

  actualDirection String?
  actualChange    Float?
  actualPrice     Float?
  wasCorrect      Boolean?

  predictionTime   DateTime  @default(now())
  verificationTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([symbol])
  @@index([modelName])
  @@index([predictionTime])
  @@index([wasCorrect])
}

model Alert {
  id        String @id @default(uuid())
  userId    Int
  symbol    String
  alertType String

  targetPrice Float?
  condition   String? @db.Text

  isActive    Boolean   @default(true)
  triggered   Boolean   @default(false)
  triggeredAt DateTime?

  message   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
  @@index([isActive])
}

model BacktestResult {
  id           String @id @default(uuid())
  strategyName String
  symbol       String
  timeframe    String

  startDate      DateTime
  endDate        DateTime
  initialBalance Float

  finalBalance   Float
  totalProfit    Float
  totalProfitPct Float
  totalTrades    Int
  winRate        Float
  profitFactor   Float
  sharpeRatio    Float
  maxDrawdown    Float
  maxDrawdownPct Float

  trades      String  @db.Text
  equityCurve String? @db.Text

  parameters String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([strategyName])
  @@index([symbol])
  @@index([startDate])
}

model ErrorLog {
  id         String  @id @default(uuid())
  level      String
  source     String
  message    String
  stackTrace String? @db.Text

  userId   Int?
  symbol   String?
  metadata String? @db.Text

  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}
